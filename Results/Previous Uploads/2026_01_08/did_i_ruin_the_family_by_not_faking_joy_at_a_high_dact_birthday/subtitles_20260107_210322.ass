Dialogue: 0,0:02:22.84,0:02:23.47,Default,,0,0,0,,{\an5}SKIP THE HOLIDAYS
Dialogue: 0,0:02:23.47,0:02:24.15,Default,,0,0,0,,{\an5}WITH US ENTIRELY
Dialogue: 0,0:02:24.15,0:02:24.65,Default,,0,0,0,,{\an5}AND SPEND
Dialogue: 0,0:02:24.65,0:02:25.31,Default,,0,0,0,,{\an5}THEM WITH HER INSTEAD.
Dialogue: 0,0:02:25.65,0:02:26.63,Default,,0,0,0,,{\an5}NO CONVERSATION,
Dialogue: 0,0:02:27.00,0:02:27.68,Default,,0,0,0,,{\an5}NO RESOLUTION,
Dialogue: 0,0:02:28.06,0:02:28.75,Default,,0,0,0,,{\an5}JUST DISTANCE
Dialogue: 0,0:02:28.75,0:02:29.30,Default,,0,0,0,,{\an5}AND SILENCE.
Dialogue: 0,0:02:29.58,0:02:30.09,Default,,0,0,0,,{\an5}I DON'T
Dialogue: 0,0:02:30.09,0:02:30.80,Default,,0,0,0,,{\an5}HATE HER, AND
Dialogue: 0,0:02:30.80,0:02:31.30,Default,,0,0,0,,{\an5}I DON'T RESENT
Dialogue: 0,0:02:31.30,0:02:32.13,Default,,0,0,0,,{\an5}THE PREGNANCY ITSELF,
Dialogue: 0,0:02:32.46,0:02:33.13,Default,,0,0,0,,{\an5}BUT I ALSO
Dialogue: 0,0:02:33.13,0:02:34.00,Default,,0,0,0,,{\an5}DON'T BELIEVE EXCITEMENT
Dialogue: 0,0:02:34.00,0:02:34.71,Default,,0,0,0,,{\an5}SHOULD BE DEMANDED,
Dialogue: 0,0:02:34.91,0:02:35.41,Default,,0,0,0,,{\an5}ESPECIALLY
Dialogue: 0,0:02:35.41,0:02:36.02,Default,,0,0,0,,{\an5}WHEN IT'S
Dialogue: 0,0:02:36.02,0:02:36.52,Default,,0,0,0,,{\an5}ANNOUNCED IN THE
Dialogue: 0,0:02:36.52,0:02:37.02,Default,,0,0,0,,{\an5}MIDDLE OF SOMEONE
Dialogue: 0,0:02:37.02,0:02:37.75,Default,,0,0,0,,{\an5}ELSE'S CELEBRATION
Dialogue: 0,0:02:37.75,0:02:38.37,Default,,0,0,0,,{\an5}AND FOLLOWED
Dialogue: 0,0:02:38.37,0:02:39.37,Default,,0,0,0,,{\an5}BY EMOTIONAL
Dialogue: 0,0:02:39.37,0:02:40.18,Default,,0,0,0,,{\an5}FALLOUT.
Dialogue: 0,0:02:40.21,0:02:41.19,Default,,0,0,0,,{\an5}I KEEP REPLAYING
Dialogue: 0,0:02:41.19,0:02:41.91,Default,,0,0,0,,{\an5}THE NIGHT IN MY HEAD,
Dialogue: 0,0:02:42.03,0:02:42.71,Default,,0,0,0,,{\an5}WONDERING IF
Dialogue: 0,0:02:42.71,0:02:43.43,Default,,0,0,0,,{\an5}I TRULY FAILED
Dialogue: 0,0:02:43.43,0:02:44.03,Default,,0,0,0,,{\an5}SOME UNSPOKEN
Dialogue: 0,0:02:44.03,0:02:44.68,Default,,0,0,0,,{\an5}FAMILY TEST,
Dialogue: 0,0:02:44.84,0:02:45.40,Default,,0,0,0,,{\an5}OR IF I
Dialogue: 0,0:02:45.40,0:02:46.18,Default,,0,0,0,,{\an5}WAS SIMPLY PUNISHED
Dialogue: 0,0:02:46.18,0:02:46.84,Default,,0,0,0,,{\an5}FOR NOT PRETENDING
Dialogue: 0,0:02:46.84,0:02:47.36,Default,,0,0,0,,{\an5}HARD ENOUGH.

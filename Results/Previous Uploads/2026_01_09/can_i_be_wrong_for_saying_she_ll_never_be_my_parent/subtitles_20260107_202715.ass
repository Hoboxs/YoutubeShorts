Dialogue: 0,0:02:22.34,0:02:22.96,Default,,0,0,0,,{\an5}I KEEP ASKING
Dialogue: 0,0:02:22.96,0:02:23.62,Default,,0,0,0,,{\an5}MYSELF IF
Dialogue: 0,0:02:23.62,0:02:24.25,Default,,0,0,0,,{\an5}I WENT TOO FAR,
Dialogue: 0,0:02:24.40,0:02:24.91,Default,,0,0,0,,{\an5}IF I
Dialogue: 0,0:02:24.91,0:02:25.71,Default,,0,0,0,,{\an5}SHOULD HAVE BEEN GENTLER,
Dialogue: 0,0:02:25.80,0:02:26.40,Default,,0,0,0,,{\an5}IF THIS
Dialogue: 0,0:02:26.40,0:02:26.97,Default,,0,0,0,,{\an5}IS JUST TEENAGE
Dialogue: 0,0:02:26.97,0:02:27.86,Default,,0,0,0,,{\an5}EMOTION COLLIDING
Dialogue: 0,0:02:27.86,0:02:28.36,Default,,0,0,0,,{\an5}WITH A DIFFICULT
Dialogue: 0,0:02:28.36,0:02:29.13,Default,,0,0,0,,{\an5}FAMILY DYNAMIC.
Dialogue: 0,0:02:29.53,0:02:30.12,Default,,0,0,0,,{\an5}BUT HOW
Dialogue: 0,0:02:30.12,0:02:30.75,Default,,0,0,0,,{\an5}LONG AM I SUPPOSED
Dialogue: 0,0:02:30.75,0:02:31.50,Default,,0,0,0,,{\an5}TO STAY QUIET
Dialogue: 0,0:02:31.50,0:02:32.21,Default,,0,0,0,,{\an5}WHILE SOMEONE INSISTS
Dialogue: 0,0:02:32.21,0:02:32.81,Default,,0,0,0,,{\an5}ON PARENTING
Dialogue: 0,0:02:32.81,0:02:33.46,Default,,0,0,0,,{\an5}ME WITHOUT EVER
Dialogue: 0,0:02:33.46,0:02:34.52,Default,,0,0,0,,{\an5}MAKING ME
Dialogue: 0,0:02:34.52,0:02:35.03,Default,,0,0,0,,{\an5}FEEL SAFE
Dialogue: 0,0:02:35.03,0:02:35.58,Default,,0,0,0,,{\an5}OR RESPECTED?
Dialogue: 0,0:02:35.78,0:02:36.28,Default,,0,0,0,,{\an5}AND WAS
Dialogue: 0,0:02:36.28,0:02:36.86,Default,,0,0,0,,{\an5}I REALLY WRONG
Dialogue: 0,0:02:36.86,0:02:37.58,Default,,0,0,0,,{\an5}FOR FINALLY SAYING
Dialogue: 0,0:02:37.58,0:02:38.09,Default,,0,0,0,,{\an5}IT OUT LOUD?

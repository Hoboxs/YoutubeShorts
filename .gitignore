# =====================
# Python environment
# =====================
.venv/
venv/
ENV/
env/

# =====================
# Python cache
# =====================
__pycache__/
*.py[cod]
*.pyo
*.pyd

# =====================
# Build / packaging
# =====================
build/
dist/
*.egg-info/
*.egg

# =====================
# Testing / tooling
# =====================
.pytest_cache/
.mypy_cache/
.tox/

# =====================
# IDEs
# =====================
.vscode/
.idea/

# =====================
# Logs / runtime files
# =====================
*.log
.pronunciation_cache/

# =====================
# Environment variables
# =====================
.env

# =====================
# OS files
# =====================
.DS_Store
Thumbs.db

# =====================
# Project-specific folders (ignored completely)
# =====================
Old Versions/
voice_samples/
TestText/

# =====================
# Output folders (keep structure, ignore contents)
# =====================
Results/**
!Results/.gitkeep

Processing/**
!Processing/.gitkeep

Failed/**
!Failed/.gitkeep

Compilation/**
!Compilation/.gitkeep

BackgroundClips/**
!BackgroundClips/.gitkeep

Tests/**
!Tests/.gitkeep

# =====================
# Excluded files
# =====================
todo.txt
AllTexts.txt
whisper_pronunciations.py
requirements copy.txt

# =====================
# Docker / build essentials (explicitly kept)
# =====================
!Dockerfile
!docker-compose.yml
!requirements.txt
!.dockerignore
!Fonts/
!Fonts/**
!AdditionalFiles/
!AdditionalFiles/**
!AdditionalFiles/*.png
!AdditionalFiles/*.jpg
!AdditionalFiles/*.jpeg